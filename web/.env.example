# 백엔드 API 서버 URL (런타임). 절대 URL을 지정하면 클라이언트가 그 주소로 직접
# 호출한다. 비워두면 동일 출처(/api/*)로 요청하고 아래 rewrite 프록시를 탄다.
# 배포(예: Vercel) 시 백엔드 도메인으로 오버라이드한다.
NEXT_PUBLIC_API_URL=http://localhost:8000

# next.config.js의 rewrites() 프록시 대상 (빌드타임). NEXT_PUBLIC_API_URL을
# 비워 동일 출처로 호출할 때 /api/* 요청이 이 주소로 전달된다. 기본값 http://localhost:8000.
# API_PROXY_TARGET=http://localhost:8000
