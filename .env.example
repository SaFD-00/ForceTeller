# ForceTeller 환경 변수 설정
# 이 파일을 복사하여 .env 파일을 생성하세요: cp .env.example .env

# ===================
# API 키 (필수)
# ===================
OPENAI_API_KEY=your_openai_api_key_here
GOOGLE_API_KEY=your_google_api_key_here

# ===================
# LLM 설정
# ===================
# 기본 LLM 제공자: "openai" | "gemini"
DEFAULT_LLM_PROVIDER=openai

# OpenAI 모델명 (GPT-5.2 기준)
# 옵션: gpt-5.2 | gpt-5.2-pro | gpt-5-mini | gpt-5-nano | gpt-5.1-codex-max
#   - gpt-5.2: 범용 플래그십, 복잡한 추론/코딩/에이전트형 작업
#   - gpt-5.2-pro: 더 깊은 추론, 높은 정밀도/난이도 문제
#   - gpt-5-mini: 비용/속도 균형, 많은 제품에서 기본값
#   - gpt-5-nano: 초고처리량, 단순 분류/지시 이행 (가장 저렴/빠름)
#   - gpt-5.1-codex-max: 코딩 에이전트 최적화
OPENAI_MODEL=gpt-5-nano

# Gemini 모델명 (Gemini 3 기준)
# 옵션: gemini-3-pro-preview | gemini-3-flash-preview | gemini-3-pro-image-preview
#   - gemini-3-pro-preview: 복잡한 작업, 고급 추론, 1M/64k context ($2/$12 per 1M tokens, >200k: $4/$18)
#   - gemini-3-flash-preview: Pro급 성능, Flash 속도/가격, 1M/64k context ($0.50/$3 per 1M tokens)
#   - gemini-3-pro-image-preview: 이미지 생성/편집, 65k/32k context ($2 text / $0.134 image)
# Knowledge cutoff: 2025년 1월
GEMINI_MODEL=gemini-3-flash-preview

# ===================
# OpenAI 세부 설정 (Responses API)
# ===================
# Reasoning effort: 추론 깊이 조절
# 옵션: "none" | "low" | "medium" | "high" | "xhigh"
#   - none: 저지연, 프롬프트 품질이 중요
#   - low ~ xhigh: 점진적으로 더 깊은 추론 (비용/지연 증가)
# 주의: temperature/top_p/logprobs는 "none"일 때만 사용 가능
OPENAI_REASONING_EFFORT=none

# Text verbosity: 출력 길이/설명량 조절
# 옵션: "low" | "medium" | "high"
#   - low: 짧고 빠른 답 (SQL 한 줄, 간단한 코드)
#   - medium: 균형 (기본값)
#   - high: 상세한 설명, 대규모 리팩터링
OPENAI_TEXT_VERBOSITY=medium

# 최대 출력 토큰
OPENAI_MAX_TOKENS=4096

# ===================
# Gemini 세부 설정
# ===================
# Thinking level: 추론 깊이 조절
# Gemini 3 Pro/Flash 공통: "low" | "high"
# Gemini 3 Flash 전용 추가: "minimal" | "medium"
#   - minimal: "no thinking" (Flash 전용), 최소 지연
#   - low: 지연/비용 최소화, 단순 채팅/고처리량
#   - medium: 균형잡힌 추론 (Flash 전용)
#   - high: 최대 추론 깊이 (기본값), 첫 토큰까지 시간 증가
GEMINI_THINKING_LEVEL=medium

# 최대 출력 토큰 (Gemini 3: 최대 64k 출력 지원)
GEMINI_MAX_TOKENS=4096

# ===================
# 서버 설정
# ===================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# CORS 허용 도메인 (콤마로 구분, "*"은 모든 도메인 허용)
# 프로덕션 예시: CORS_ORIGINS=https://your-app.vercel.app,https://custom-domain.com
CORS_ORIGINS=*

# ===================
# 세션 설정
# ===================
SESSION_MAX_HISTORY=20
SESSION_TIMEOUT_MINUTES=60

# ===================
# 만세력 설정
# ===================
DEFAULT_CITY=Seoul
USE_TRUE_SOLAR_TIME=true
