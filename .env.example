# ForceTeller 환경 변수 설정
# 이 파일을 복사하여 .env 파일을 생성하세요: cp .env.example .env

# ===================
# API 키 (필수)
# ===================
# OpenRouter API 키 (https://openrouter.ai/keys 에서 발급)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ===================
# LLM 설정 (OpenRouter 단일 게이트웨이)
# ===================
# OpenRouter는 OpenAI 호환 API로, 아래 6개 모델을 지원합니다.
#   - openai/gpt-oss-120b:free   : 무료, OpenAI 오픈 모델 (기본값)
#   - openai/gpt-oss-20b:free    : 무료, 경량 (라우팅용)
#   - google/gemma-4-26b-a4b-it:free : 무료, MoE, 구조화 출력 안정적
#   - google/gemma-4-31b-it:free : 무료 (폴백)
#   - deepseek/deepseek-v4-flash : 유료, 빠르고 저렴
#   - deepseek/deepseek-v4-pro   : 유료, 최고 품질 (1M 컨텍스트)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_ROUTING_MODEL=openai/gpt-oss-20b:free
OPENROUTER_FALLBACK_MODEL=google/gemma-4-31b-it:free

# 요청이 지정할 수 있는 모델 화이트리스트 (콤마 구분). 채팅 API가 이 목록으로
# 요청 모델을 검증한다. 기본값은 위 6개 지원 모델 전체.
# OPENROUTER_ALLOWED_MODELS=openai/gpt-oss-120b:free,openai/gpt-oss-20b:free,google/gemma-4-26b-a4b-it:free,google/gemma-4-31b-it:free,deepseek/deepseek-v4-flash,deepseek/deepseek-v4-pro

# 호출 파라미터
OPENROUTER_MAX_TOKENS=4096
OPENROUTER_REASONING_EFFORT=medium   # low | medium | high
OPENROUTER_TEMPERATURE=0.7

# OpenRouter 랭킹용 헤더 (선택)
OPENROUTER_SITE_URL=https://forceteller.app
OPENROUTER_APP_NAME=ForceTeller

# ===================
# 서버 설정
# ===================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# CORS 허용 도메인 (콤마로 구분, "*"은 모든 도메인 허용)
# 프로덕션 예시: CORS_ORIGINS=https://your-app.vercel.app,https://custom-domain.com
CORS_ORIGINS=*

# ===================
# 레이트리밋 (IP별 슬라이딩 윈도우, 인메모리)
# ===================
# 공개 배포 시 남용·비용 폭주 1차 방어선. LLM 엔드포인트(/api/chat*)는 별도의 엄격 한도.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60            # 전역 기본: IP당 창(window)별 최대 요청 수
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_LLM_REQUESTS=12        # LLM 라우트(/api/chat, /api/chat/stream): 더 엄격
RATE_LIMIT_LLM_WINDOW_SECONDS=60
# 프록시(Railway/Vercel) 뒤에서 true — X-Forwarded-For 최좌측 IP를 클라이언트로 신뢰.
# API를 직접 노출하면 false로 두어 헤더 스푸핑 우회를 막으세요.
RATE_LIMIT_TRUST_FORWARDED=true

# ===================
# DB 영속화 (선택)
# ===================
# 미설정 시 로컬 SQLite 파일(./forceteller.db)을 사용합니다.
# 프로덕션(Railway 등)에서는 관리형 PostgreSQL을 주입하세요.
#   예: DATABASE_URL=postgresql+asyncpg://user:password@host:5432/forceteller
# DATABASE_URL=sqlite+aiosqlite:///./forceteller.db

# ===================
# 세션 설정
# ===================
SESSION_MAX_HISTORY=20         # 세션당 보관할 최대 메시지 수
SESSION_TIMEOUT_MINUTES=60     # 세션 TTL(분). 경과 시 조회 불가·정리 대상
MAX_SESSIONS=100               # 인메모리 매니저의 최대 동시 세션 수
SESSION_CLEANUP_PERCENTAGE=0.2 # 상한 초과 시 오래된 세션을 정리할 비율(0~1)
CONVERSATION_HISTORY_LIMIT=10  # LLM에 전달할 최근 대화 턴 수

# ===================
# 로깅 설정
# ===================
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ===================
# 만세력 설정
# ===================
DEFAULT_CITY=Seoul
USE_TRUE_SOLAR_TIME=true
